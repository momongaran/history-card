{
  "version": "3.9",
  "description": "コンポーザブル因果フレーム定義 — 固定B-F-Eを関数型フレームに置換",
  "designRationale": "B-F-Eの3スロットを固定するのではなく、因果フレーム(Fname)が構造を決定する。各Fnameはパラメータのロール・数・必須性を定義し、背景合成フレーム(Bname)がネスト可能。これにより、圧力解放型に限らない多様な因果構造を自然に表現できる。",
  "notation": "<Fname>(role1: value1, role2: value2, ...): 解放",

  "causalFrames": {
    "圧力解放": {
      "id": "CF_pressure_release",
      "nameEn": "Pressure-Release",
      "signature": "圧力解放(背景: Bname, 揺らぎ: text): 解放",
      "description": "蓄積された構造的矛盾・圧力が、特定の揺らぎ（引き金）により爆発的に解放される",
      "params": [
        {"role": "背景", "type": "Bname", "required": true, "description": "蓄積された圧力。Bnameでの合成を許容"},
        {"role": "揺らぎ", "type": "text", "required": true, "description": "解放を誘発する引き金・契機"}
      ],
      "result": {"role": "解放", "description": "圧力の爆発的解放"},
      "oldMapping": {"背景": "B(pressure)", "揺らぎ": "F(trigger)", "解放": "E(release)"},
      "typicalExamples": ["壬申の乱", "応仁の乱", "正長の土一揆", "桜田門外の変"],
      "eventCount": 63
    },

    "主体的行為": {
      "id": "CF_deliberate_action",
      "nameEn": "Deliberate-Action",
      "signature": "主体的行為(状況: Bname, 判断: text): 帰結",
      "description": "行為者が状況を認知し、目的を持って意思決定・行為する",
      "params": [
        {"role": "状況", "type": "Bname", "required": true, "description": "行為者が認知する状況・条件"},
        {"role": "判断", "type": "text", "required": true, "description": "行為者の意思決定"}
      ],
      "result": {"role": "帰結", "description": "行為の帰結・結果"},
      "oldMapping": {"状況": "B(situation)", "判断": "F(judgment)", "帰結": "E(action_outcome)"},
      "typicalExamples": ["大宝律令制定", "遣唐使派遣", "安土城築城", "廃藩置県"],
      "eventCount": 58
    },

    "外生衝撃": {
      "id": "CF_exogenous_shock",
      "nameEn": "Exogenous-Shock",
      "signature": "外生衝撃(受容状態: Bname, 衝撃: text): 適応",
      "description": "外部からの衝撃がシステムに作用し、適応・対応を迫られる",
      "params": [
        {"role": "受容状態", "type": "Bname", "required": true, "description": "衝撃を受ける側のシステム状態"},
        {"role": "衝撃", "type": "text", "required": true, "description": "外部からの衝撃"}
      ],
      "result": {"role": "適応", "description": "適応・対応結果"},
      "oldMapping": {"受容状態": "B(receiving_state)", "衝撃": "F(shock)", "適応": "E(adaptation)"},
      "typicalExamples": ["仏教伝来", "元寇", "鉄砲伝来", "関東大震災"],
      "eventCount": 21
    },

    "矛盾露呈": {
      "id": "CF_contradiction_exposure",
      "nameEn": "Contradiction-Exposure",
      "signature": "矛盾露呈(潜在矛盾: Bname, 顕在化契機: text): 構造変化",
      "description": "潜在的矛盾が顕在化し、漸進的な構造変化を引き起こす。圧力解放型に近いが瞬間的爆発ではない",
      "params": [
        {"role": "潜在矛盾", "type": "Bname", "required": true, "description": "潜在的に存在する構造的矛盾"},
        {"role": "顕在化契機", "type": "text", "required": true, "description": "矛盾が表面化する契機"}
      ],
      "result": {"role": "構造変化", "description": "漸進的な構造変化"},
      "oldMapping": {"潜在矛盾": "B(latent_contradiction)", "顕在化契機": "F(exposure_trigger)", "構造変化": "E(structural_change)"},
      "typicalExamples": ["墾田永年私財法", "承久の乱の帰結", "鎌倉幕府滅亡"],
      "eventCount": 48
    },

    "権力移行": {
      "id": "CF_power_transition",
      "nameEn": "Power-Transition",
      "signature": "権力移行(権力空白: Bname, 後継手続: text?): 新体制",
      "description": "権力ポストの空白が駆動力。解放すべき圧力ではなく、空きが埋まるプロセス",
      "params": [
        {"role": "権力空白", "type": "Bname", "required": true, "description": "前体制の終焉・ポスト空白"},
        {"role": "後継手続", "type": "text", "required": false, "description": "後継争い・選定手続。スムーズな移行では省略可"}
      ],
      "result": {"role": "新体制", "description": "新体制の成立"},
      "oldMapping": {"権力空白": "B(power_vacuum)", "後継手続": "F(succession)", "新体制": "E(new_regime)"},
      "typicalExamples": ["継体天皇即位", "藤原良房摂政就任", "徳川家康将軍就任"],
      "eventCount": 8
    },

    "偶発連鎖": {
      "id": "CF_contingency_cascade",
      "nameEn": "Contingency-Cascade",
      "signature": "偶発連鎖(脆弱性: Bname, 偶発事象: text): 連鎖帰結",
      "description": "偶然の出来事がシステムの脆弱点に触れ、連鎖反応を引き起こす",
      "params": [
        {"role": "脆弱性", "type": "Bname", "required": true, "description": "システムの構造的脆弱性"},
        {"role": "偶発事象", "type": "text", "required": true, "description": "偶然の出来事"}
      ],
      "result": {"role": "連鎖帰結", "description": "連鎖反応の帰結"},
      "oldMapping": {"脆弱性": "B(vulnerability)", "偶発事象": "F(accident)", "連鎖帰結": "E(cascade_result)"},
      "typicalExamples": ["生麦事件", "応天門の変"],
      "eventCount": 9
    }
  },

  "backgroundFrames": {
    "_description": "背景合成フレーム (Bname): 背景要素を組み合わせて具体的な「背景」を生成する。因果フレームのパラメータにネストされる。",

    "制度的矛盾": {
      "id": "BF_institutional_contradiction",
      "nameEn": "Institutional-Contradiction",
      "signature": "制度的矛盾(要素A: BG, 要素B: BG, ...): 制度間の緊張",
      "description": "複数の制度・法が矛盾し緊張を生む",
      "params": [
        {"role": "要素", "type": "BG_ref", "required": true, "multiple": true, "description": "矛盾する制度群"}
      ],
      "result": "制度間の構造的緊張",
      "typicalExamples": ["律令制と荘園制の矛盾", "幕府法と朝廷法の併存"]
    },

    "勢力対立": {
      "id": "BF_power_rivalry",
      "nameEn": "Power-Rivalry",
      "signature": "勢力対立(勢力A: BG, 勢力B: BG, ...): 対立の圧",
      "description": "複数の勢力が対立・競合する構図",
      "params": [
        {"role": "勢力", "type": "BG_ref", "required": true, "multiple": true, "description": "対立する勢力群"}
      ],
      "result": "勢力間の対立圧",
      "typicalExamples": ["蘇我氏vs物部氏", "源氏vs平氏", "幕府vs朝廷"]
    },

    "権力集中": {
      "id": "BF_power_concentration",
      "nameEn": "Power-Concentration",
      "signature": "権力集中(権力体: BG): 集中のもとでの支配圧",
      "description": "単一の権力体が支配的地位を占める状態",
      "params": [
        {"role": "権力体", "type": "BG_ref", "required": true, "multiple": false, "description": "支配的権力体"}
      ],
      "result": "集権的支配状態",
      "typicalExamples": ["蘇我氏の専横", "摂関家の独占", "徳川幕藩体制"]
    },

    "思想潮流": {
      "id": "BF_ideological_current",
      "nameEn": "Ideological-Current",
      "signature": "思想潮流(思想: BG, 社会状態: BG?): 思想的圧力",
      "description": "思想・宗教・文化的潮流が社会に作用する",
      "params": [
        {"role": "思想", "type": "BG_ref", "required": true, "multiple": false, "description": "思想・宗教・文化要素"},
        {"role": "社会状態", "type": "BG_ref", "required": false, "multiple": false, "description": "思想が作用する社会の状態"}
      ],
      "result": "思想的圧力・変容力",
      "typicalExamples": ["仏教の浸透", "儒教的秩序観", "尊王攘夷思想"]
    },

    "経済圧": {
      "id": "BF_economic_pressure",
      "nameEn": "Economic-Pressure",
      "signature": "経済圧(経済構造: BG, 階層: BG?): 経済的緊張",
      "description": "経済構造の変化・矛盾が社会的緊張を生む",
      "params": [
        {"role": "経済構造", "type": "BG_ref", "required": true, "multiple": false, "description": "経済的構造要素"},
        {"role": "階層", "type": "BG_ref", "required": false, "multiple": false, "description": "影響を受ける社会階層"}
      ],
      "result": "経済的緊張",
      "typicalExamples": ["荘園経済の矛盾", "幕藩財政の窮迫", "米価変動と武士困窮"]
    },

    "外圧環境": {
      "id": "BF_external_pressure",
      "nameEn": "External-Pressure",
      "signature": "外圧環境(国際環境: BG, 国内状態: BG?): 外圧",
      "description": "国際環境・外部要因が国内に影響を及ぼす",
      "params": [
        {"role": "国際環境", "type": "BG_ref", "required": true, "multiple": false, "description": "国際環境要素"},
        {"role": "国内状態", "type": "BG_ref", "required": false, "multiple": false, "description": "外圧を受ける国内状態"}
      ],
      "result": "外圧",
      "typicalExamples": ["唐の文明圧力", "モンゴル帝国の脅威", "西洋列強の開国圧力"]
    },

    "制度疲弊": {
      "id": "BF_institutional_decay",
      "nameEn": "Institutional-Decay",
      "signature": "制度疲弊(制度: BG): 制度的空洞化",
      "description": "既存制度が機能不全に陥り空洞化する",
      "params": [
        {"role": "制度", "type": "BG_ref", "required": true, "multiple": false, "description": "疲弊する制度"}
      ],
      "result": "制度的空洞化・形骸化",
      "typicalExamples": ["律令制の形骸化", "室町幕府の機能不全", "幕藩体制の動揺"]
    },

    "複合背景": {
      "id": "BF_composite",
      "nameEn": "Composite",
      "signature": "複合背景(要素: BG|Bname, ...): 複合的背景",
      "description": "他のBnameの出力や背景要素を自由に組み合わせる汎用パターン。特定パターンに該当しない場合に使用",
      "params": [
        {"role": "要素", "type": "BG_ref|Bname", "required": true, "multiple": true, "description": "任意の背景要素またはBnameの出力"}
      ],
      "result": "複合的背景",
      "typicalExamples": []
    }
  },

  "compositionRules": {
    "nesting": "Fnameの背景パラメータにBnameをネスト可能。Bnameのパラメータに別のBnameをネスト可能（深さ制限なし）",
    "resultSemantics": "Fnameの結果(result)は常に「解放」の一般化。これが背景要素の作用状態(phases)を変化させる発火点",
    "bgRef": "BG_ref型はbackgroundElementsのbgIdを参照する",
    "optionalParams": "?付きパラメータは省略可能。構造がシンプルな場合に使用"
  },

  "examples": {
    "_note": "既存イベントのフレーム変換例",

    "壬申の乱": {
      "eventId": "EV_p0672_01",
      "frame": {
        "fname": "圧力解放",
        "params": {
          "背景": {
            "bname": "勢力対立",
            "params": {
              "勢力": ["BG_041", "BG_005"]
            },
            "label": "天智系と天武系の皇位継承をめぐる対立"
          },
          "揺らぎ": "天智天皇の死と大友皇子の即位"
        },
        "result": {
          "role": "解放",
          "label": "天武天皇の即位と律令国家体制の確立"
        }
      }
    },

    "大宝律令制定": {
      "eventId": "EV_p0701_01",
      "frame": {
        "fname": "主体的行為",
        "params": {
          "状況": {
            "bname": "外圧環境",
            "params": {
              "国際環境": "BG_010",
              "国内状態": "BG_041"
            },
            "label": "唐の律令制度という先進モデルと、国内統治の制度化需要"
          },
          "判断": "文武天皇・藤原不比等らが唐律令を範とした本格的法典編纂を決定"
        },
        "result": {
          "role": "帰結",
          "label": "日本初の体系的律令の制定"
        }
      }
    },

    "元寇": {
      "eventId": "EV_p1274_01",
      "frame": {
        "fname": "外生衝撃",
        "params": {
          "受容状態": {
            "bname": "権力集中",
            "params": {
              "権力体": "BG_006"
            },
            "label": "北条得宗家主導の鎌倉幕府体制"
          },
          "衝撃": "モンゴル帝国（元）の日本侵攻"
        },
        "result": {
          "role": "適応",
          "label": "防衛成功するも御家人への恩賞不足が幕府動揺の遠因に"
        }
      }
    },

    "継体天皇即位": {
      "eventId": "EV_p0507_01",
      "frame": {
        "fname": "権力移行",
        "params": {
          "権力空白": {
            "bname": "制度疲弊",
            "params": {
              "制度": "BG_041"
            },
            "label": "武烈天皇が後継なく崩御し大王位が空位"
          },
          "後継手続": "大伴金村らが応神天皇五世孫を越前から迎え入れ"
        },
        "result": {
          "role": "新体制",
          "label": "継体天皇即位・新王統の開始"
        }
      }
    }
  }
}
